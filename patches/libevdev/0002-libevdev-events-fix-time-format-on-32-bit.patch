From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Paper Linux <paper@localhost>
Date: Mon, 2 Mar 2026 18:35:00 +0000
Subject: [PATCH] libevdev-events: fix time formatting on 32-bit targets

On 32-bit targets with 64-bit time_t, printing input_event timestamps
with %ld is undefined behavior and can crash the tool. Cast through
intmax_t and use PRIdMAX instead.

---
--- a/tools/libevdev-events.c
+++ b/tools/libevdev-events.c
@@ -8,6 +8,7 @@
 #include <assert.h>
 #include <errno.h>
 #include <fcntl.h>
+#include <inttypes.h>
 #include <linux/input.h>
 #include <stdio.h>
 #include <string.h>
@@ -94,14 +95,14 @@
 print_event(struct input_event *ev)
 {
 	if (ev->type == EV_SYN)
-		printf("Event: time %ld.%06ld, ++++++++++++++++++++ %s +++++++++++++++\n",
-				ev->input_event_sec,
-				ev->input_event_usec,
+		printf("Event: time %" PRIdMAX ".%06" PRIdMAX ", ++++++++++++++++++++ %s +++++++++++++++\n",
+				(intmax_t)ev->input_event_sec,
+				(intmax_t)ev->input_event_usec,
 				libevdev_event_type_get_name(ev->type));
 	else
-		printf("Event: time %ld.%06ld, type %d (%s), code %d (%s), value %d\n",
-			ev->input_event_sec,
-			ev->input_event_usec,
+		printf("Event: time %" PRIdMAX ".%06" PRIdMAX ", type %d (%s), code %d (%s), value %d\n",
+			(intmax_t)ev->input_event_sec,
+			(intmax_t)ev->input_event_usec,
 			ev->type,
 			libevdev_event_type_get_name(ev->type),
 			ev->code,
